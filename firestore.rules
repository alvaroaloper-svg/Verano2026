rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection storing usernames, local password controls, and events
    match /users/{userId} {
      // Allow getting individual documents for signin and creating them for signup
      allow get: if true;
      allow create: if true;
      
      // Allow updates to save/manage personal schedules
      allow update: if true;
      
      // Prevent deleting user profiles in this setup
      allow delete: if false;
    }
  }
}
